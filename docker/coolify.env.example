# Salin nilai ke Coolify → Environment Variables (runtime).
# Domain / URL jangan letak dalam Dockerfile — guna pembolehubah di bawah.
#
# Coolify: tandakan APP_ENV=production (dan APP_DEBUG=false) sebagai "Runtime only"
# supaya ia tidak disuntik semasa `docker build` (elak amaran / isu Composer).

# --- Wajib ---
APP_NAME=OrbitRTMF
APP_KEY=base64:...                    # Coolify boleh jana / php artisan key:generate --show
APP_DEBUG=false
APP_URL=https://katalog.sena.my       # URL awam yang dilayani (sama dengan UI jika satu imej ini)

DB_CONNECTION=pgsql
DB_HOST=...                           # Host DB dari servis PostgreSQL Coolify
DB_PORT=5432
DB_DATABASE=orbitrtmf
DB_USERNAME=...
DB_PASSWORD=...

# CORS: asal UI (SPA). Mesti sepadan dengan domain pelayar pengguna.
FRONTEND_URL=https://katalog.sena.my

# Sanctum SPA — senarai host (tanpa skema), dipisahkan koma.
SANCTUM_STATEFUL_DOMAINS=katalog.sena.my

# Kongsi sesi antara subdomain *.sena.my (jika UI & API subdomain berbeza)
SESSION_DOMAIN=.sena.my
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

# --- Disyorkan production ---
LOG_CHANNEL=stack
LOG_LEVEL=warning

# Migrasi automatik pada setiap restart kontena (elakkan jika >1 replika serentak)
MIGRATE_ON_START=false

# -----------------------------------------------------------------------------
# Build-time (Coolify → Build Arguments), hanya jika UI dan API di subdomain berasingan
# -----------------------------------------------------------------------------
# VITE_API_BASE_URL=https://katalog-api.sena.my
#
# Jika UI dan API dilayan imej ini yang sama (satu domain): jangan set, atau set string kosong.
